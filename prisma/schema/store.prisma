// Store Model
model Store {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  logo        String?
  banner      String?

  // Owner
  sellerId String
  seller   User      @relation(fields: [sellerId], references: [id])
  products Product[]
  carts    Cart[]    // Carts currently scoped to this store

  // Status & Visibility
  status StoreStatus @default(PENDING)
  isOpen Boolean     @default(false)

  // Operational
  deliveryRadiusKm Float
  minimumOrder     Float

  // Location
  address   String
  latitude  Float
  longitude Float

  // Business Hours
  openingTime String // HH:mm
  closingTime String // HH:mm

  // Timestamps
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // Soft delete — never hard delete

  @@index([sellerId])
  @@index([status])
  @@map("store")
}
