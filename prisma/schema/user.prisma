// User Model
model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  phone    String?
  password String? // Nullable for Google users
  role     Role    @default(CUSTOMER)

  // Auth & Security
  isEmailVerified     Boolean   @default(false)
  isBlocked           Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?

  // Profile
  avatar     String?
  provider   AuthProvider @default(LOCAL)
  providerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions   Session[]
  accounts   Account[] // Kept for flexibility/Better Auth default
  stores     Store[]    // A seller can have multiple stores
  categories Category[]
  cart       Cart?      // One active cart per customer

  @@map("user")
}
