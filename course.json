    {
      "name": "Auth",
      "description": "OTP-based signup verification plus Better Auth session requests. Use the OTP endpoints for registration and email verification, then use Better Auth sign-in to establish the session cookie for protected routes.",
      "item": [
        {
          "name": "Auth - Register With OTP Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Register a new student account through the OTP signup flow.\n\nThis creates the user and sends a verification OTP email. After this request, call Auth - Verify Email OTP before sign-in.",
