        {
          "name": "Auth - Sign In With Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "description": "Sign in with Better Auth email/password after email verification. A successful response should establish the session cookie used by protected business routes.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"StrongPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-in/email",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "sign-in",
                "email"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Get Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const sessionUserId = body?.user?.id || body?.session?.userId;",
                  "  if (sessionUserId) {",
                  "    pm.collectionVariables.set('userId', sessionUserId);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "description": "Inspect the current Better Auth session. Use this after sign-in to verify that Postman is sending the stored session cookie.",
            "url": {
              "raw": "{{baseUrl}}/api/auth/get-session",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "get-session"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Auth - Sign Out",
          "request": {
            "method": "POST",
            "header": [],
            "description": "Terminate the current Better Auth session.",
            "url": {
              "raw": "{{baseUrl}}/api/auth/sign-out",
