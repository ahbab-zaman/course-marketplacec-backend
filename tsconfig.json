{
  "compilerOptions": {
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "types": ["node"],
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/modules/store/**/*",
    "src/modules/product/**/*",
    "src/modules/cart/**/*",
    "src/modules/category/**/*",
    "src/middlewares/auth.middleware.ts"
  ]
}
